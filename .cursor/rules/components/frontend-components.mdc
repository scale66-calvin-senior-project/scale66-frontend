export const Modal: React.FC<ModalProps> = ({ ... }) => {
  // Implementation
};
```

## Testing Considerations

Structure for testability:
1. Extract complex logic to custom hooks
2. Accept data as props (avoid internal fetching)
3. Use data-testid attributes
4. Keep components focused (single responsibility)

```typescript
export const Component: React.FC<Props> = ({ data, onAction }) => {
  return (
    <div data-testid="component-container">
      {data.map((item) => (
        <div key={item.id} data-testid={`item-${item.id}`}>
          {item.name}
        </div>
      ))}
    </div>
  );
};
```
