## Barrel Exports

```typescript
// index.ts
export { ComponentName } from "./ComponentName";
export type { ComponentNameProps } from "./ComponentName";
```

Enables clean imports:
```typescript
// CORRECT
import { ComponentName } from "@/components/ui/ComponentName";

// INCORRECT
import { ComponentName } from "@/components/ui/ComponentName/ComponentName";
```

## Component Types

### UI Components (components/ui/)

Base reusable components: Button, Input, Card, Modal, Dropdown, Checkbox, Spinner

Characteristics:
- Generic and reusable
- Accept styling through className
- Minimal internal state
- No API calls or business logic

### Common Components (components/common/)

Shared with business logic: EmptyState, ErrorBoundary, LoadingSpinner, SuccessMessage

Characteristics:
- Application-specific but reusable
- May include default content/styling
- Can have internal state
- No external data fetching

### Layout Components (components/layouts/)

Page structure: AppLayout, AuthLayout, LandingLayout (Navbar, Footer)

Characteristics:
- Define page structure
- Handle navigation
- May integrate with context
- Can fetch global data

## Props Patterns

### Required vs Optional

```typescript
export interface ComponentProps {
  // Required (no default)
  id: string;
  title: string;
  
  // Optional (with defaults)
  variant?: "primary" | "secondary";
  size?: "sm" | "md" | "lg";
  isLoading?: boolean;
  
  // Optional (no defaults)
  description?: string;
  onClick?: () => void;
  className?: string;
}
```

### Extending HTML Props

```typescript
export interface ButtonProps extends React.ButtonHTMLAttributes<HTMLButtonElement> {
  variant?: "primary" | "secondary";
  isLoading?: boolean;
}

export const Button: React.FC<ButtonProps> = ({
  variant = "primary",
  isLoading,
  children,
  className,
  disabled,
  ...props
}) => {
  return (
    <button
      className={`${styles.button} ${styles[variant]} ${className || ""}`}
      disabled={disabled || isLoading}
      {...props}
    >
      {isLoading ? <Spinner /> : children}
    </button>
  );
};
```

## State Management

### Local State

```typescript
import { useState } from 'react';

export const Component: React.FC = () => {
  const [isOpen, setIsOpen] = useState(false);
  const [value, setValue] = useState('');
  
  return (/* Component JSX */);
};
```

### Context

```typescript
import { useContext } from "react";
import { AuthContext } from "@/context/AuthContext";

export const Component: React.FC = () => {
  const { user, isAuthenticated } = useContext(AuthContext);
  
  if (!isAuthenticated) return <div>Please log in</div>;
  
  return <div>Welcome, {user.email}</div>;
};
```

### Custom Hooks

```typescript
import { useAuth } from "@/hooks/useAuth";
import { useDebounce } from "@/hooks/useDebounce";

export const Component: React.FC = () => {
  const { user } = useAuth();
  const [search, setSearch] = useState("");
  const debouncedSearch = useDebounce(search, 500);
  
  // Use debouncedSearch for API calls
};
```

## Event Handlers

```typescript
export const Component: React.FC = () => {
  const handleClick = () => {
    // Handle click
  };
  
  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    // Handle form submission
  };
  
  const handleChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    setValue(e.target.value);
  };
  
  return (
    <form onSubmit={handleSubmit}>
      <input onChange={handleChange} />
      <button onClick={handleClick}>Submit</button>
    </form>
  );
};
```

## Conditional Rendering

```typescript
export const Component: React.FC<Props> = ({ isLoading, error, data }) => {
  if (isLoading) return <LoadingSpinner />;
  if (error) return <ErrorBoundary error={error} />;
  if (!data || data.length === 0) return <EmptyState message="No data available" />;
  
  return (
    <div>
      {data.map((item) => (
        <div key={item.id}>{item.name}</div>
      ))}
    </div>
  );
};
```

