# ============================================================
# SUPABASE CONFIGURATION (REQUIRED)
# Get these from: Supabase Dashboard > Settings > API
# ============================================================

# Project URL (Settings > API > Project URL)
SUPABASE_URL=https://your-project-id.supabase.co

# Anon/Public Key (Settings > API > Project API keys > anon public)
# Used for client-side operations, respects Row Level Security
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (Settings > API > Project API keys > service_role)
# WARNING: This key bypasses RLS - keep it secret!
# Used for backend admin operations
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret (Settings > API > JWT Settings > JWT Secret)
# Used to verify JWT tokens from Supabase Auth
SUPABASE_JWT_SECRET=your-jwt-secret-from-settings


# ============================================================
# AI SERVICES (REQUIRED for content generation)
# ============================================================

# Anthropic (Claude) - Text generation and analysis
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini - Image generation
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# Gemini image model selection:
#   - gemini-3-pro-image-preview (recommended: highest quality, supports 4K)
#   - gemini-2.5-flash-image (faster, cost-effective)
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview


# ============================================================
# OPTIONAL SERVICES
# ============================================================

# Email Service (Resend)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_AUDIENCE_ID=...

# Social Media OAuth
INSTAGRAM_CLIENT_ID=...
INSTAGRAM_CLIENT_SECRET=...
TIKTOK_CLIENT_KEY=...
TIKTOK_CLIENT_SECRET=...

# Stripe Payments
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...


# ============================================================
# APP SETTINGS
# ============================================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True
ENVIRONMENT=development

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=False

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000
